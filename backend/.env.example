# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/birthday-reminder

# Server
PORT=5000

# Gmail + Nodemailer (use an App Password for Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Birthday Reminder <your-email@gmail.com>"

# Cron: daily at 7:00 AM (server local time)
# node-cron format: minute hour day month weekday
CRON_SCHEDULE=0 7 * * *
